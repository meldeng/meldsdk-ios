// Meld demo credentials — the .env equivalent for an Xcode app.
//
// Copy this file to `Secrets.xcconfig` (gitignored) and fill in your sandbox values:
//     cp Secrets.example.xcconfig Secrets.xcconfig
//
// These are exposed to the app via Info.plist ($(MELD_API_KEY)) and read at runtime.
// You can also override either value with a scheme Environment Variable of the same name.

MELD_API_KEY =
MELD_CUSTOMER_ID =

// Optional — API host (no scheme; we prepend https://). Defaults to api-sb.meld.io (sandbox).
// Set to api-qa.meld.io if your key/customer live in QA.
MELD_API_HOST =

// Optional — corridor. Defaults to a EU corridor (EUR / FR / BTC) because Mercuryo's native Apple
// Pay does NOT process US/GB users or cards. Override here for your account — e.g. set
// MELD_COUNTRY=US and MELD_SOURCE_CURRENCY=USD if your customer only supports that (card flow only;
// Apple Pay won't complete on a US corridor).
MELD_SOURCE_CURRENCY =
MELD_DEST_CURRENCY =
MELD_COUNTRY =
