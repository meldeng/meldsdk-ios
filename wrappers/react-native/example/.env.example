# Copy to .env and fill in. The .env file is gitignored — never commit real credentials.
# POC only: a real app creates orders on its backend, so the app never holds the API key.

MELD_API_KEY=
MELD_CUSTOMER_ID=
# Host only, no scheme. Use api-qa.meld.io for QA, api-sb.meld.io for sandbox.
MELD_API_HOST=api-sb.meld.io
